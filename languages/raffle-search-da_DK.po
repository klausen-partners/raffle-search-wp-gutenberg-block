#. Plugin Name of the plugin
msgid "Raffle Search"
msgstr "Raffle Søgning"

#. Description of the plugin
msgid "A Gutenberg block that integrates Raffle AI search (top questions, autocomplete, summary, and search results)."
msgstr "En Gutenberg-blok der integrerer Raffle AI-søgning (populære spørgsmål, autofuldførelse, resumé og søgeresultater)."

#: includes/admin.php
msgctxt "settings menu title"
msgid "Raffle Search"
msgstr "Raffle Søgning"

#: includes/admin.php
msgid "API Configuration"
msgstr "API-konfiguration"

#: includes/admin.php
msgid "Enter your Raffle AI credentials. Find these in the Raffle Web App under your API User Interface settings."
msgstr "Indtast dine Raffle AI-legitimationsoplysninger. Find dem i Raffle Web App under dine API User Interface-indstillinger."

#: includes/admin.php
msgid "Base URL"
msgstr "Basis-URL"

#: includes/admin.php
msgid "The Raffle API base URL. Defaults to https://api.raffle.ai/v2."
msgstr "Raffle API-basis-URL. Standardværdi er https://api.raffle.ai/v2."

#: includes/admin.php
msgid "Search UID"
msgstr "Søgnings-UID"

#: includes/admin.php
msgid "The UID of your Raffle Search UI (Tool UID). Found in the Install modal of your tool in the Raffle Web App."
msgstr "UID for din Raffle Search UI (Værktøjs-UID). Findes i installationsvinduet for dit værktøj i Raffle Web App."

#: includes/admin.php
msgid "Show References"
msgstr "Vis referencer"

#: includes/admin.php
msgid "Display the References list below the AI summary."
msgstr "Vis referencelisten under AI-resuméet."

#: includes/admin.php
msgid "Settings saved successfully."
msgstr "Indstillinger gemt."

#: includes/admin.php
msgid "Save Settings"
msgstr "Gem indstillinger"

